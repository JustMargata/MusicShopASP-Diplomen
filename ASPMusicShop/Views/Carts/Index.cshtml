@model IEnumerable<ASPMusicShop.Data.Cart>

@{
    ViewData["Title"] = "Моята количка";
    decimal total = ViewBag.CartTotal != null ? (decimal)ViewBag.CartTotal : 0m;
}

<div class="admin-page">
    <div class="admin-card">
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
            <div>
                <h1 class="section-title mb-1">Моята количка</h1>
                <p class="section-subtitle">Прегледай добавените продукти.</p>
            </div>

            <div class="d-flex gap-2 flex-wrap">
                <a asp-controller="Products" asp-action="Index" class="btn-secondary-custom">
                    <i class="bi bi-arrow-left"></i> Към продуктите
                </a>

                <a asp-action="Orders" class="btn-secondary-custom">
                    <i class="bi bi-bag-check"></i> Моите поръчки
                </a>
            </div>
        </div>

        @if (!Model.Any())
        {
            <div class="empty-cart-box text-center">
                <i class="bi bi-cart-x empty-cart-icon"></i>
                <h3 class="mt-3 mb-2">Количката е празна</h3>
                <p class="section-subtitle mb-4">Все още нямаш добавени продукти.</p>

                <a asp-controller="Products" asp-action="Index" class="btn-primary-custom">
                    <i class="bi bi-bag"></i> Разгледай продукти
                </a>
            </div>
        }
        else
        {
            <div class="cart-list">
                @foreach (var item in Model)
                {
                    <div class="cart-item-card">
                        <div class="cart-item-image">
                            <img src="@item.Products.ImageURL" alt="@item.Products.Name" />
                        </div>

                        <div class="cart-item-body">
                            <div class="cart-item-top">
                                <div>
                                    <h4 class="cart-item-title">@item.Products.Name</h4>
                                    <p class="cart-item-meta mb-1">@item.Products.Model</p>
                                    <p class="cart-item-meta mb-0">@item.Products.Categories?.Name</p>
                                </div>

                                <div class="cart-item-price">
                                    @((item.Products.Price * item.Quantity).ToString("0.00")) €
                                </div>
                            </div>

                            <div class="cart-item-bottom">
                                <div class="cart-qty-box">
                                    <form asp-action="Decrease" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="cart-qty-btn">
                                            <i class="bi bi-dash"></i>
                                        </button>
                                    </form>

                                    <span class="cart-qty-value">@item.Quantity</span>

                                    <form asp-action="Increase" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="cart-qty-btn">
                                            <i class="bi bi-plus"></i>
                                        </button>
                                    </form>
                                </div>

                                <form asp-action="Remove" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn-danger-soft">
                                        <i class="bi bi-trash"></i> Премахни
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="cart-summary-card mt-4">
                <div class="cart-summary-row">
                    <span>Обща сума</span>
                    <strong>@total.ToString("0.00") €</strong>
                </div>

                <div class="mt-3 d-flex justify-content-end">
                    <form asp-action="Checkout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-primary-custom">
                            <i class="bi bi-bag-check"></i> Поръчай
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
</div>