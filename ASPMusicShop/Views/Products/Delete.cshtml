@model ASPMusicShop.Data.Product

@{
    ViewData["Title"] = "Изтриване на продукт";
}

<div class="admin-page">
    <div class="delete-card">
        <div class="delete-icon-wrap">
            <div class="delete-icon">
                <i class="bi bi-trash3-fill"></i>
            </div>
        </div>

        <h1 class="section-title text-center mb-2">Изтриване на продукт</h1>
        <p class="section-subtitle text-center mb-4">
            Сигурен ли си, че искаш да изтриеш този продукт?
        </p>

        <div class="delete-product-card">
            <div class="delete-product-image">
                <img src="@Model.ImageURL" alt="@Model.Name" />
            </div>

            <div class="delete-product-body">
                <h3>@Model.Name</h3>
                <p class="mb-1 text-muted">@Model.Model</p>
                <p class="mb-1"><strong>Категория:</strong> @Model.Categories?.Name</p>
                <p class="mb-1"><strong>Цена:</strong> @Model.Price €</p>
                <p class="mb-1"><strong>Баркод:</strong> @Model.Barcode</p>
                <p class="mb-0"><strong>Описание:</strong> @Model.Description</p>
            </div>
        </div>

        <form asp-action="Delete" class="mt-4 d-flex justify-content-center gap-2 flex-wrap">
            <input type="hidden" asp-for="Id" />

            <button type="submit" class="btn-danger-soft">
                <i class="bi bi-trash"></i> Да, изтрий
            </button>

            <a asp-action="Index" class="btn-secondary-custom">
                <i class="bi bi-arrow-left"></i> Отказ
            </a>
        </form>
    </div>
</div>